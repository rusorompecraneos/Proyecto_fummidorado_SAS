<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Documentos – Fumi Dorado</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <div style="min-height:100vh; background:var(--color-bg); padding: var(--space-8);">

    <div style="max-width: 960px; margin: 0 auto; display:flex; flex-direction:column; gap: var(--space-8);">

      <!-- HEADER -->
      <div style="padding-bottom: var(--space-5); border-bottom: 2px solid var(--color-gold);">
        <a href="javascript:history.back()" class="page-header__back" style="margin-bottom: var(--space-3); display:inline-flex;">
          <span style="font-size:1.3rem; margin-right:var(--space-2);">←</span> Volver
        </a>
        <h1 class="page-header__title">Diagramas UPC / HDS y FT</h1>
        <p class="page-header__subtitle">Cargar diagramas / HDS y FT</p>
      </div>

      <!-- SELECTOR -->
      <div class="module-selector">

        <a href="/admin/documentos/diagramas-upc" style="text-decoration:none;">
          <div class="module-selector__card">
            <div class="module-selector__icon">📄</div>
            <div class="module-selector__title">Diagramas UPC</div>
            <div class="module-selector__desc">Gestionar Diagramas UPC</div>
          </div>
        </a>

        <a href="/admin/documentos/hds-ft" style="text-decoration:none;">
          <div class="module-selector__card">
            <div class="module-selector__icon">📄</div>
            <div class="module-selector__title">HDS y FT</div>
            <div class="module-selector__desc">Gestionar HDS y FT</div>
          </div>
        </a>

      </div>
    </div>
  </div>
</body>
</html>