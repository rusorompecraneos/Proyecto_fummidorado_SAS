<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tipos de Servicio - Fumi Dorado</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<div class="layout">

  <%- include('../partials/sidebar.ejs', { currentPage: 'tipoServicio' }) %>

  <main class="main-content">

    <!-- Flecha volver al dashboard -->
    <a href="/dashboard/<%= user.rol %>" class="auth-back-link" style="margin-bottom: var(--space-4);">
      ← Volver al dashboard
    </a>

    <!-- Encabezado -->
    <div class="page-header">
      <div>
        <h2 class="page-header__title">Tipos de Servicio</h2>
        <p class="page-header__subtitle">Administra los tipos de servicio del sistema</p>
      </div>
      <!-- Solo admin puede registrar -->
      <% if (user.rol === 'admin') { %>
        <button class="btn btn--primary">+ Registrar Tipo</button>
      <% } %>
    </div>

    <!-- Tabla -->
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Estado</th>
            <% if (user.rol === 'admin') { %>
              <th>Acciones</th>
            <% } %>
          </tr>
        </thead>
        <tbody>
          <% tiposServicio.forEach(tipo => { %>
          <tr>
            <td><%= tipo.nombre %></td>
            <td><%= tipo.descripcion %></td>
            <td>
              <% if (tipo.estado === 'Activo') { %>
                <span class="badge badge--success">Activo</span>
              <% } else { %>
                <span class="badge badge--error">Inactivo</span>
              <% } %>
            </td>
            <% if (user.rol === 'admin') { %>
            <td>
              <div class="table-actions">
                <button class="btn-icon btn-icon--view" title="Ver">👁️</button>
                <button class="btn-icon" title="Editar">✏️</button>
                <button class="btn-icon btn-icon--danger" title="Inactivar">🗑️</button>
              </div>
            </td>
            <% } %>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  </main>
</div>
</body>
</html>
