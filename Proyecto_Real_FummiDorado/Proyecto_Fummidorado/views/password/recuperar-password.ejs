<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Recuperar Contraseña – Fumi Dorado</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <div class="auth-page">
    <div class="auth-card">

      <div class="auth-card__logo">
        <div class="auth-card__logo-icon">FD</div>
        <h1 class="auth-card__title">Recuperar Contraseña</h1>
        <p class="auth-card__subtitle">
          Ingresa tu número de teléfono para recibir un código de verificación
        </p>
      </div>
      
      <% if (error) { %>
        <div class="alert alert--error" style="margin-bottom: var(--space-4);">
          ⚠ <%= error %>
        </div>
      <% } %>
      
      <form class="auth-card__form" action="/password/recuperar" method="POST">
        <div class="form-group">
          <label class="form-label">Número de teléfono</label>
          <div class="input-phone">
            <span class="input-phone__prefix">📞</span>
            <input
              type="tel"
              name="telefono"
              placeholder="Ej: 3001234567"
            />
          </div>
        </div>

        <button type="submit" class="btn btn--primary btn--lg">
          Enviar código
        </button>
      </form>

      <div class="text-center">
        <a href="/usuario/logout" class="auth-back-link">← Volver al login</a>
      </div>

    </div>
  </div>
</body>
</html>