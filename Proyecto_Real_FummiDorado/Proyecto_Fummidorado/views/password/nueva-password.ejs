<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nueva Contraseña – Fumi Dorado</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <div class="auth-page">
    <div class="auth-card">

      <div class="auth-card__logo">
        <div class="auth-card__logo-icon">🔒</div>
        <h1 class="auth-card__title">Crear nueva contraseña</h1>
        <p class="auth-card__subtitle">
          Ingresa tu nueva contraseña para actualizar tu cuenta
        </p>
      </div>
       <% if (error) { %>
        <div class="alert alert--error" style="margin-bottom: var(--space-4);">
          ⚠ <%= error %>
        </div>
      <% } %>
      <form class="auth-card__form" action="/password/nueva-password" method="POST">
        <div class="form-group">
          <label class="form-label">Nueva contraseña</label>
          <div class="input-password">
            <input
              class="form-control"
              type="password"
              id="nueva_password"
              name="nueva_password"
              placeholder="Mínimo 6 caracteres"
            />
            <button type="button" class="input-password__toggle" onclick="togglePass('nueva_password', this)">
              👁️
            </button>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Confirmar contraseña</label>
          <div class="input-password">
            <input
              class="form-control"
              type="password"
              id="confirmar_password"
              name="confirmar_password"
              placeholder="Repite la contraseña"
            />
            <button type="button" class="input-password__toggle" onclick="togglePass('confirmar_password', this)">
              👁️
            </button>
          </div>
        </div>

        <button type="submit" class="btn btn--primary btn--lg">
          Actualizar contraseña
        </button>
      </form>

    </div>
  </div>

  <script>
    function togglePass(id, btn) {
      const input = document.getElementById(id);
      if (input.type === 'password') {
        input.type = 'text';
        btn.textContent = '🙈';
      } else {
        input.type = 'password';
        btn.textContent = '👁️';
      }
    }
  </script>
</body>
</html>