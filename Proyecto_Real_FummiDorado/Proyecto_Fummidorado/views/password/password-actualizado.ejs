<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contraseña Actualizada – Fumi Dorado</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <div class="auth-page">
    <div class="auth-card" style="max-width: 560px; text-align: center;">

      <div class="auth-success">
        <div class="auth-success__icon">✅</div>

        <h1 class="auth-success__title">
          ¡Contraseña actualizada correctamente!
        </h1>

        <p class="auth-success__desc">
          Tu contraseña ha sido actualizada exitosamente. Ahora puedes iniciar sesión con tu nueva contraseña.
        </p>

        <a href="/login" class="btn btn--primary btn--lg">
          Volver al login
        </a>

        <p class="auth-success__countdown" id="countdown">
          Serás redirigido automáticamente en 3 segundos ...
        </p>
      </div>

    </div>
  </div>

  <script>
    let segundos = 3;
    const texto = document.getElementById('countdown');

    const intervalo = setInterval(() => {
      segundos--;
      texto.textContent = `Serás redirigido automáticamente en ${segundos} segundos ...`;
      if (segundos <= 0) {
        clearInterval(intervalo);
        window.location.href = '/login';
      }
    }, 1000);
  </script>
</body>
</html>