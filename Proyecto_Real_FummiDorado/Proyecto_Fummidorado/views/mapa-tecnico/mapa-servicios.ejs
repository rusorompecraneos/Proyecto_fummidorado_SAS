<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mapa de Servicios – Fumi Dorado</title>
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <style>
    #mapa {
      width: 100%;
      height: 420px;
      border-radius: var(--radius-lg);
      border: 1px solid var(--color-border);
      z-index: 0;
    }
    .leaflet-top, .leaflet-bottom { z-index: 1 !important; }
    .leyenda {
      display: flex;
      align-items: center;
      gap: var(--space-6);
      padding: var(--space-3) var(--space-5);
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
    }
    .leyenda__item {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      font-size: var(--text-sm);
      color: var(--color-text-muted);
    }
    .leyenda__dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .lista-servicios {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      overflow: hidden;
    }
    .lista-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: var(--space-4) var(--space-5);
      border-bottom: 1px solid var(--color-border);
      cursor: pointer;
      transition: background var(--transition-fast);
    }
    .lista-item:last-child { border-bottom: none; }
    .lista-item:hover { background: var(--color-gold-muted); }
    .lista-item__nombre {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      font-size: var(--text-sm);
      color: var(--color-text);
    }
    .lista-item__hora {
      font-size: var(--text-sm);
      font-weight: var(--weight-semi);
      color: var(--color-gold);
    }
  </style>
</head>
<body>
<div style="min-height:100vh; background:var(--color-bg); padding: var(--space-8);">
  <div style="max-width: 900px; margin: 0 auto; display:flex; flex-direction:column; gap: var(--space-6);">

    <!-- HEADER -->
    <div style="padding-bottom: var(--space-5); border-bottom: 2px solid var(--color-gold);">
      <a href="/dashboard/tecnico" class="page-header__back" style="margin-bottom: var(--space-3); display:inline-flex;">
        <span style="font-size:1.3rem; margin-right:var(--space-2);">←</span> Volver
      </a>
      <h1 class="page-header__title">Mapa de servicios</h1>
      <p class="page-header__subtitle">Bogotá, Cundinamarca</p>
    </div>

    <!-- LEYENDA -->
    <div class="leyenda">
      <div class="leyenda__item">
        <div class="leyenda__dot" style="background: var(--color-warning);"></div>
        Pendiente
      </div>
      <div class="leyenda__item">
        <div class="leyenda__dot" style="background: var(--color-success);"></div>
        Completado
      </div>
      <div class="leyenda__item">
        <div class="leyenda__dot" style="background: var(--color-info);"></div>
        Tu ubicación
      </div>
    </div>

    <!-- MAPA -->
    <div id="mapa"></div>

    <!-- LISTA DE SERVICIOS -->
    <div class="lista-servicios">
      <% servicios.forEach(function(s) { %>
        <div class="lista-item" onclick="centrarEn(<%= s.lat %>, <%= s.lng %>)">
          <div class="lista-item__nombre">
            <div class="leyenda__dot" style="background: <%= s.estado === 'Completado' ? '#3dba7a' : '#e6a817' %>; flex-shrink:0;"></div>
            <%= s.cliente %>
          </div>
          <div class="lista-item__hora"><%= s.hora %></div>
        </div>
      <% }) %>
    </div>

  </div>
</div>

<!-- Leaflet JS -->
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<!-- Datos del servidor → variable global para el JS externo -->
<script>
  window.serviciosData = <%- serviciosJSON %>;
</script>

<!-- Lógica del mapa en archivo externo -->
<script src="/js/mapa-servicios.js"></script>
</body>
</html>

