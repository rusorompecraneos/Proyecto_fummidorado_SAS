<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HDS y FT – Fumi Dorado</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <div style="min-height:100vh; background:var(--color-bg); padding: var(--space-8);">
    <div style="max-width: 960px; margin: 0 auto; display:flex; flex-direction:column; gap: var(--space-8);">

      <!-- HEADER -->
      <div style="padding-bottom: var(--space-5); border-bottom: 2px solid var(--color-gold);">
        <a href="javascript:history.back()" class="page-header__back" style="margin-bottom: var(--space-3); display:inline-flex;">
          <span style="font-size:1.3rem; margin-right:var(--space-2);">←</span> Volver
        </a>
        <h1 class="page-header__title">HDS y FT</h1>
        <p class="page-header__subtitle">
          <% if (rol === 'admin') { %>Gestionar HDS y FT<% } else { %>Documentación técnica de productos utilizados<% } %>
        </p>
      </div>

      <!-- BUSCADOR + BOTÓN ADMIN -->
      <div style="display:flex; align-items:center; gap: var(--space-4);">
        <div class="card" style="padding: var(--space-4); flex:1;">
          <div class="search-bar">
            <span class="search-bar__icon">🔍</span>
            <input type="text" id="buscador" placeholder="Buscar HDS / FT" oninput="filtrar()" />
          </div>
        </div>
        <% if (rol === 'admin') { %>
          <button class="btn btn--primary" style="white-space:nowrap; height:fit-content;">
            + Cargar Nuevo Documento
          </button>
        <% } %>
      </div>

      <!-- GRID DE DOCUMENTOS -->
      <div class="grid grid-3" id="lista-documentos">

        <div class="diagram-card documento" data-nombre="K-Othrine SC 62.5">
          <div class="diagram-card__header">
            <div class="diagram-card__file-icon">📄</div>
            <div>
              <div class="diagram-card__name">CITROSAN</div>
              <span class="badge badge--hds">HDS</span>
            </div>
          </div>
          <div class="diagram-card__meta">I.A.: Deltametrina</div>
          <div class="diagram-card__date">Última actualización: <strong>14/01/2026</strong></div>
          <div class="diagram-card__actions" style="display:flex; gap: var(--space-2); flex-wrap:wrap;">
            <a href="/documentos/_HDS_CITROSAN.pdf" download class="btn btn--primary" style="flex:1;">⬇ Descargar PDF</a>
            <% if (rol === 'admin') { %>
              <button class="btn-icon" title="Editar">✏️</button>
              <button class="btn-icon btn-icon--danger" title="Eliminar">🗑️</button>
            <% } %>
          </div>
        </div>

        <div class="diagram-card documento" data-nombre="Klerat">
          <div class="diagram-card__header">
            <div class="diagram-card__file-icon">📄</div>
            <div>
              <div class="diagram-card__name">CITROSAN</div>
              <span class="badge badge--ft">FT</span>
            </div>
          </div>
          <div class="diagram-card__meta">I.A.: Brodifacum</div>
          <div class="diagram-card__date">Última actualización: <strong>31/01/2026</strong></div>
          <div class="diagram-card__actions" style="display:flex; gap: var(--space-2); flex-wrap:wrap;">
            <a href="/documentos/FT_CITROSAN.pdf" download class="btn btn--primary" style="flex:1;">⬇ Descargar PDF</a>
            <% if (rol === 'admin') { %>
              <button class="btn-icon" title="Editar">✏️</button>
              <button class="btn-icon btn-icon--danger" title="Eliminar">🗑️</button>
            <% } %>
          </div>
        </div>

        <div class="diagram-card documento" data-nombre="Storm">
          <div class="diagram-card__header">
            <div class="diagram-card__file-icon">📄</div>
            <div>
              <div class="diagram-card__name">SIPERTRIN</div>
              <span class="badge badge--hds">HDS</span>
            </div>
          </div>
          <div class="diagram-card__meta">I.A.: Flocoumafen</div>
          <div class="diagram-card__date">Última actualización: <strong>04/02/2026</strong></div>
          <div class="diagram-card__actions" style="display:flex; gap: var(--space-2); flex-wrap:wrap;">
            <a href="documentos/HDS_SIPERTRIN.pdf" download class="btn btn--primary" style="flex:1;">⬇ Descargar PDF</a>
            <% if (rol === 'admin') { %>
              <button class="btn-icon" title="Editar">✏️</button>
              <button class="btn-icon btn-icon--danger" title="Eliminar">🗑️</button>
            <% } %>
          </div>
        </div>

      </div>

      <p class="text-muted text-center hidden" id="sin-resultados">
        No se encontraron documentos con ese nombre.
      </p>

      <!-- INFO BOX solo para cliente y tecnico -->
      <% if (rol !== 'admin') { %>
        <div class="info-box">
          <div class="info-box__header">📋 Información Importante</div>
          <ul class="info-box__list">
            <li>Las Hojas de Seguridad (HDS) contienen información sobre manejo seguro, primeros auxilios y medidas de emergencia.</li>
            <li>Las Fichas Técnicas (FT) detallan las características, aplicaciones y dosificaciones de cada producto.</li>
            <li>Todos los documentos se actualizan periódicamente según normativa vigente.</li>
          </ul>
        </div>
      <% } %>

    </div>
  </div>

  <script>
    function filtrar() {
      const busqueda = document.getElementById('buscador').value.toLowerCase();
      const documentos = document.querySelectorAll('.documento');
      let visibles = 0;
      documentos.forEach(function(doc) {
        const nombre = doc.getAttribute('data-nombre').toLowerCase();
        if (nombre.includes(busqueda)) { doc.style.display = ''; visibles++; }
        else { doc.style.display = 'none'; }
      });
      document.getElementById('sin-resultados').classList.toggle('hidden', visibles > 0);
    }
  </script>
</body>
</html>