<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Diagramas UPC – Fumi Dorado</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <div style="min-height:100vh; background:var(--color-bg); padding: var(--space-8);">
    <div style="max-width: 960px; margin: 0 auto; display:flex; flex-direction:column; gap: var(--space-8);">

      <!-- HEADER -->
      <div style="padding-bottom: var(--space-5); border-bottom: 2px solid var(--color-gold);">
        <a href="javascript:history.back()" class="page-header__back" style="margin-bottom: var(--space-3); display:inline-flex;">
          <span style="font-size:1.3rem; margin-right:var(--space-2);">←</span> Volver
        </a>
        <h1 class="page-header__title">Diagramas UPC</h1>
        <p class="page-header__subtitle">
          <% if (rol === 'admin') { %>Gestionar diagramas UPC<% } else { %>Visualizar diagramas de puntos de control<% } %>
        </p>
      </div>

      <!-- BUSCADOR + BOTÓN ADMIN -->
      <div style="display:flex; align-items:center; gap: var(--space-4);">
        <div class="card" style="padding: var(--space-4); flex:1;">
          <div class="search-bar">
            <span class="search-bar__icon">🔍</span>
            <input type="text" id="buscador" placeholder="Buscar Diagramas" oninput="filtrar()" />
          </div>
        </div>
        <% if (rol === 'admin') { %>
          <button class="btn btn--primary" style="white-space:nowrap; height:fit-content;">
            + Cargar Nuevo Diagrama
          </button>
        <% } %>
      </div>

      <!-- GRID -->
      <div class="grid grid-3" id="lista-diagramas">

        <div class="diagram-card diagrama" data-nombre="Hotel Metropol">
          <div class="diagram-card__header">
            <div class="diagram-card__file-icon">📄</div>
            <div>
              <div class="diagram-card__name">Hotel Metropol</div>
              <span class="badge badge--upc">Hoteles</span>
            </div>
          </div>
          <div class="diagram-card__meta">Diagrama de ubicación de puntos de control para áreas comunes</div>
          <div class="diagram-card__date">Fecha: <strong>4/4/2026</strong></div>
          <div class="diagram-card__actions" style="display:flex; gap: var(--space-2); flex-wrap:wrap;">
            <a href="#" class="btn btn--primary" style="flex:1;">👁 Ver</a>
            <% if (rol === 'admin') { %>
              <button class="btn-icon" title="Editar">✏️</button>
              <button class="btn-icon btn-icon--danger" title="Eliminar">🗑️</button>
            <% } else { %>
              <a href="#" download class="btn btn--secondary" style="flex:1;">⬇ Descargar</a>
            <% } %>
          </div>
        </div>

        <div class="diagram-card diagrama" data-nombre="Restaurante El Buen Sabor">
          <div class="diagram-card__header">
            <div class="diagram-card__file-icon">📄</div>
            <div>
              <div class="diagram-card__name">Restaurante El Buen Sabor</div>
              <span class="badge badge--upc">Restaurantes</span>
            </div>
          </div>
          <div class="diagram-card__meta">Diagrama de puntos de control</div>
          <div class="diagram-card__date">Fecha: <strong>19/3/2026</strong></div>
          <div class="diagram-card__actions" style="display:flex; gap: var(--space-2); flex-wrap:wrap;">
            <a href="#" class="btn btn--primary" style="flex:1;">👁 Ver</a>
            <% if (rol === 'admin') { %>
              <button class="btn-icon" title="Editar">✏️</button>
              <button class="btn-icon btn-icon--danger" title="Eliminar">🗑️</button>
            <% } else { %>
              <a href="#" download class="btn btn--secondary" style="flex:1;">⬇ Descargar</a>
            <% } %>
          </div>
        </div>

        <div class="diagram-card diagrama" data-nombre="Oficinas Tech Corp">
          <div class="diagram-card__header">
            <div class="diagram-card__file-icon">📄</div>
            <div>
              <div class="diagram-card__name">Oficinas Tech Corp</div>
              <span class="badge badge--upc">Oficinas</span>
            </div>
          </div>
          <div class="diagram-card__meta">Diagrama de puntos de control</div>
          <div class="diagram-card__date">Fecha: <strong>19/4/2026</strong></div>
          <div class="diagram-card__actions" style="display:flex; gap: var(--space-2); flex-wrap:wrap;">
            <a href="#" class="btn btn--primary" style="flex:1;">👁 Ver</a>
            <% if (rol === 'admin') { %>
              <button class="btn-icon" title="Editar">✏️</button>
              <button class="btn-icon btn-icon--danger" title="Eliminar">🗑️</button>
            <% } else { %>
              <a href="#" download class="btn btn--secondary" style="flex:1;">⬇ Descargar</a>
            <% } %>
          </div>
        </div>

      </div>

      <p class="text-muted text-center hidden" id="sin-resultados">
        No se encontraron diagramas con ese nombre.
      </p>

    </div>
  </div>

  <script>
    function filtrar() {
      const busqueda = document.getElementById('buscador').value.toLowerCase();
      const diagramas = document.querySelectorAll('.diagrama');
      let visibles = 0;
      diagramas.forEach(function(d) {
        const nombre = d.getAttribute('data-nombre').toLowerCase();
        if (nombre.includes(busqueda)) { d.style.display = ''; visibles++; }
        else { d.style.display = 'none'; }
      });
      document.getElementById('sin-resultados').classList.toggle('hidden', visibles > 0);
    }
  </script>
</body>
</html>