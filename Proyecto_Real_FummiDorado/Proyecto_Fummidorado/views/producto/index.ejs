<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Productos - Fumi Dorado</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<div class="layout">

  <%- include('../partials/sidebar.ejs', { currentPage: 'producto' }) %>

  <main class="main-content">

    <!-- Flecha volver al dashboard -->
    <a href="/dashboard/<%= user.rol %>" class="auth-back-link" style="margin-bottom: var(--space-4);">
      ← Volver al dashboard
    </a>

    <!-- Encabezado -->
    <div class="page-header">
      <div>
        <h2 class="page-header__title">Matriz de Rotación de Productos</h2>
        <p class="page-header__subtitle">Programación de uso de productos por mes</p>
      </div>
      <!-- Solo admin puede registrar -->
      <% if (user.rol === 'admin') { %>
        <button class="btn btn--primary">+ Registrar Producto</button>
      <% } %>
    </div>

    <!-- Tabla -->
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Ingrediente Activo</th>
            <th>Concentración</th>
            <th>Tipo</th>
            <th>Meses de Uso</th>
            <th>Estado</th>
            <!-- Solo admin ve columna acciones -->
            <% if (user.rol === 'admin') { %>
              <th>Acciones</th>
            <% } %>
          </tr>
        </thead>
        <tbody>
          <% productos.forEach(producto => { %>
          <tr>
            <td>
              <div><%= producto.nombre %></div>
              <small class="text-muted"><%= producto.descripcion %></small>
            </td>
            <td><%= producto.ingredienteActivo %></td>
            <td><%= producto.concentracion %></td>
            <td>
              <% if (producto.tipoProducto === 'Insecticida') { %>
                <span class="badge badge--insecticida">Insecticida</span>
              <% } else { %>
                <span class="badge badge--rodenticida">Rodenticida</span>
              <% } %>
            </td>
            <td>
              <div style="display:flex; flex-wrap:wrap; gap:4px;">
                <% producto.mesesUso.forEach(mes => { %>
                  <span class="badge badge--gold"><%= mes %></span>
                <% }) %>
              </div>
            </td>
            <td>
              <% if (producto.estado === 'Activo') { %>
                <span class="badge badge--success">Activo</span>
              <% } else { %>
                <span class="badge badge--error">Inactivo</span>
              <% } %>
            </td>
            <!-- Acciones solo para admin -->
            <% if (user.rol === 'admin') { %>
            <td>
              <div class="table-actions">
                <button class="btn-icon btn-icon--view" title="Ver">👁️</button>
                <button class="btn-icon" title="Editar">✏️</button>
                <button class="btn-icon btn-icon--danger" title="Eliminar">🗑️</button>
              </div>
            </td>
            <% } %>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  </main>
</div>
</body>
</html>
