<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Órdenes de Servicio - Fumi Dorado</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<div class="layout">

  <%- include('../partials/sidebar.ejs', { currentPage: 'ordenServicio' }) %>

  <<main class="main-content <%= user.rol !== 'admin' ? 'main-content--full' : '' %>">

    <!-- Navbar para técnico/cliente (sin sidebar) -->
    <%- include('../partials/navbar.ejs') %>

    <!-- Flecha volver al dashboard -->
    <a href="/dashboard/<%= user.rol %>" class="auth-back-link" style="margin-bottom: var(--space-4);">
      ← Volver al dashboard
    </a>

    <!-- Encabezado -->
    <div class="page-header">
      <div>
        <h2 class="page-header__title">
          <% if (user.rol === 'cliente') { %>
            Mis Servicios
          <% } else { %>
            Gestión de Servicios
          <% } %>
        </h2>
        <p class="page-header__subtitle">
          <% if (user.rol === 'cliente') { %>
            Consulta el estado de tus servicios contratados
          <% } else if (user.rol === 'tecnico') { %>
            Órdenes de servicio asignadas
          <% } else { %>
            Administra órdenes de servicio
          <% } %>
        </p>
      </div>
      <!-- Solo admin puede crear -->
      <% if (user.rol === 'admin') { %>
        <button class="btn btn--primary">+ Crear Servicio</button>
      <% } %>
    </div>

    <!-- Tabla -->
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>OS</th>
            <th>Fecha</th>
            <th>Hora</th>
            <!-- Cliente no ve la columna Técnico -->
            <% if (user.rol !== 'cliente') { %>
              <th>Cliente</th>
              <th>Sede</th>
            <% } %>
            <th>Técnico</th>
            <th>Estado</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% ordenes.forEach(orden => { %>
          <tr>
            <td class="text-gold"><%= orden.codigoOs %></td>
            <td><%= orden.fechaProgramada %></td>
            <td><%= orden.horaInicio %></td>
            <% if (user.rol !== 'cliente') { %>
              <td><%= orden.nombreCliente %></td>
              <td><%= orden.nombreSede %></td>
            <% } %>
            <td><%= orden.nombreTecnico %></td>
            <td>
              <% if (orden.estado === 'Por ejecutar') { %>
                <span class="badge badge--ejecutar">Por ejecutar</span>
              <% } else if (orden.estado === 'Finalizado') { %>
                <span class="badge badge--finalizado">Finalizado</span>
              <% } else if (orden.estado === 'En proceso') { %>
                <span class="badge badge--proceso">En proceso</span>
              <% } else { %>
                <span class="badge badge--cancelado">Cancelado</span>
              <% } %>
            </td>
            <td>
              <div class="table-actions">
                <!-- Ver: todos pueden -->
                <a href="/ordenServicio/<%= orden.idOrden %>" class="btn-icon btn-icon--view" title="Ver">👁️</a>
                <!-- Editar y eliminar: solo admin -->
                <% if (user.rol === 'admin') { %>
                  <button class="btn-icon" title="Editar">✏️</button>
                  <button class="btn-icon btn-icon--danger" title="Eliminar">🗑️</button>
                <% } %>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  </main>
</div>
</body>
</html>
