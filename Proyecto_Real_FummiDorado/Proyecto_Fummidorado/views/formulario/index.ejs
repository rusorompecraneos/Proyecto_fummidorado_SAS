<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Formularios - Fumi Dorado</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="layout">

        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="navbar__brand" style="padding: 0 var(--space-5); margin-bottom: var(--space-6);">
                <div class="navbar__logo">FD</div>
                <div>
                    <div class="navbar__title">Fumi Dorado</div>
                    <div class="navbar__subtitle">Panel Admin</div>
                </div>
            </div>
            <a href="/tipoServicio" class="sidebar__item">⚙️ Tipos de Servicio</a>
            <a href="/ordenServicio" class="sidebar__item">📋 Órdenes de Servicio</a>
            <a href="/formulario" class="sidebar__item active">📝 Formularios</a>
            <a href="/producto" class="sidebar__item">🧪 Productos</a>
        </aside>

        <!-- Contenido principal -->
        <main class="main-content">

            <!-- Encabezado -->
            <div class="page-header">
                <div>
                    <h2 class="page-header__title">Formularios de Servicio</h2>
                    <p class="page-header__subtitle">Consulta los formularios diligenciados por los técnicos</p>
                </div>
            </div>

            <!-- Tabla -->
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>OS</th>
                            <th>Cliente</th>
                            <th>Sede</th>
                            <th>Técnico</th>
                            <th>Fecha</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% formularios.forEach(formulario => { %>
                        <tr>
                            <td class="text-gold"><%= formulario.codigoOs %></td>
                            <td><%= formulario.nombreCliente %></td>
                            <td><%= formulario.nombreSede %></td>
                            <td><%= formulario.nombreTecnico %></td>
                            <td><%= formulario.fechaServicio %></td>
                            <td>
                                <% if(formulario.estado === 'Finalizado') { %>
                                    <span class="badge badge--finalizado">Finalizado</span>
                                <% } else { %>
                                    <span class="badge badge--proceso">En proceso</span>
                                <% } %>
                            </td>
                            <td>
                                <div class="table-actions">
                                    <a href="/formulario/<%= formulario.idFormulario %>" class="btn-icon btn-icon--view" title="Ver">👁️</a>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

        </main>
    </div>
</body>
</html>