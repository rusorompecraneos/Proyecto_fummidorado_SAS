<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Servicios de Hoy – Fumi Dorado</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <div style="min-height:100vh; background:var(--color-bg); padding: var(--space-8);">

    <!-- HEADER -->
    <div style="padding-bottom: var(--space-5); border-bottom: 2px solid var(--color-gold); margin-bottom: var(--space-8);">
      <a href="javascript:history.back()" class="page-header__back" style="margin-bottom: var(--space-3); display:inline-flex;">
        <span style="font-size:1.3rem; margin-right:var(--space-2);">←</span> Volver
      </a>
      <h1 class="page-header__title">Servicios de Hoy</h1>
      <p class="page-header__subtitle">Resumen del día</p>
    </div>

     <div style="max-width: 1100px; margin: 0 auto; display:flex; flex-direction:column; gap: var(--space-8);">

      <!-- TARJETAS DE ESTADÍSTICAS -->
      <div class="grid grid-3">

        <div class="card">
          <div class="flex-between" style="margin-bottom: var(--space-3);">
            <p class="card__subtitle" style="margin:0;">Total de servicios</p>
            <span style="font-size:1.4rem;">📅</span>
          </div>
          <div style="font-size: var(--text-3xl); font-weight: var(--weight-bold); color: var(--color-gold);">
            <%= estadisticas.total %>
          </div>
          <a href="#" class="auth-link" style="font-size: var(--text-xs); margin-top: var(--space-2); display:block;">
            Servicios programados
          </a>
        </div>

        <div class="card">
          <div class="flex-between" style="margin-bottom: var(--space-3);">
            <p class="card__subtitle" style="margin:0;">Completados</p>
            <span style="font-size:1.4rem;">✅</span>
          </div>
          <div style="font-size: var(--text-3xl); font-weight: var(--weight-bold); color: var(--color-success);">
            <%= estadisticas.completados %>
          </div>
          <p style="font-size: var(--text-xs); color: var(--color-text-faint); margin:0; margin-top: var(--space-2);">
            Servicios finalizados
          </p>
        </div>

        <div class="card">
          <div class="flex-between" style="margin-bottom: var(--space-3);">
            <p class="card__subtitle" style="margin:0;">Pendientes</p>
            <span style="font-size:1.4rem;">⚠️</span>
          </div>
          <div style="font-size: var(--text-3xl); font-weight: var(--weight-bold); color: var(--color-warning);">
            <%= estadisticas.pendientes %>
          </div>
          <p style="font-size: var(--text-xs); color: var(--color-text-faint); margin:0; margin-top: var(--space-2);">
            Por completar
          </p>
        </div>

      </div>

      <!-- LISTA DE SERVICIOS -->
      <div class="card">
        <h3 class="card__title" style="margin-bottom: var(--space-6);">Lista de servicios del dia</h3>

        <div style="display:flex; flex-direction:column; gap: var(--space-4);">
          <% servicios.forEach(function(servicio) { %>
            <%
              var colorBorde = servicio.estado === 'Completado' ? 'var(--color-success)' : 'var(--color-warning)';
              var iconoEstado = servicio.estado === 'Completado' ? '✅' : '⚠️';
              var badgeClase = servicio.estado === 'Completado' ? 'badge--finalizado' : 'badge--ejecutar';

            %>
            <div class="card card--elevated" style="border-left: 4px solid <%= colorBorde %>; border-radius: var(--radius-md); padding: var(--space-4) var(--space-5);">

              <div class="flex-between" style="margin-bottom: var(--space-3);">
                <div style="display:flex; align-items:center; gap: var(--space-2);">
                  <span style="font-size:1.2rem;"><%= iconoEstado %></span>
                  <div>
                    <div style="font-weight: var(--weight-semi); font-size: var(--text-md); color: var(--color-text);">
                      <%= servicio.cliente %>
                    </div>
                    <div style="font-size: var(--text-xs); color: var(--color-text-faint);">
                      SVR-<%= servicio.id %>
                    </div>
                  </div>
                </div>
                <span class="badge <%= badgeClase %>">
                  <%= servicio.estado %>
                </span>
              </div>

              <div class="flex-between">
                <div style="display:flex; flex-direction:column; gap: var(--space-2);">
                  <div style="font-size: var(--text-sm); color: var(--color-text-muted);">
                    🕐 <%= servicio.hora %>
                  </div>
                  <div style="font-size: var(--text-sm); color: var(--color-text-muted);">
                    Tipo: <strong style="color: var(--color-text);"><%= servicio.tipo %></strong>
                  </div>
                </div>
                <div style="font-size: var(--text-sm); color: var(--color-text-muted); text-align:right;">
                  📍 <%= servicio.direccion %>
                </div>
              </div>

            </div>
          <% }) %>
        </div>
      </div>

    </div>
  </div>
</body>
</html>