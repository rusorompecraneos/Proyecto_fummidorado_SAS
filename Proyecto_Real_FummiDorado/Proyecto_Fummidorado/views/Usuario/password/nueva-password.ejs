<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nueva Contraseña – Fumi Dorado</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background-color: #1a1a1a;
      color: #ffffff;
      font-family: 'Segoe UI', sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .card {
      background-color: #242424;
      border-radius: 16px;
      padding: 2.5rem 2rem;
      width: 100%;
      max-width: 460px;
      text-align: center;
    }

    .logo {
      background-color: #D4A017;
      width: 70px;
      height: 70px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.5rem;
      font-size: 2rem;
    }

    h1 { font-size: 1.6rem; font-weight: 700; margin-bottom: 0.75rem; }

    .subtitulo {
      color: #aaaaaa;
      font-size: 0.95rem;
      margin-bottom: 2rem;
      line-height: 1.5;
    }

    .campo { text-align: left; margin-bottom: 1.25rem; }

    .campo label {
      display: block;
      font-size: 0.9rem;
      font-weight: 500;
      margin-bottom: 0.4rem;
    }

    .input-wrap {
      display: flex;
      align-items: center;
      background-color: #333;
      border: 1.5px solid #444;
      border-radius: 8px;
      padding: 0 0.85rem;
      transition: border-color 0.2s;
    }

    .input-wrap:focus-within { border-color: #D4A017; }

    .input-wrap span { color: #888; font-size: 1rem; margin-right: 0.5rem; }

    .input-wrap input {
      background: transparent;
      border: none;
      outline: none;
      color: #fff;
      font-size: 0.95rem;
      padding: 0.75rem 0;
      width: 100%;
    }

    .toggle-pass {
      background: none;
      border: none;
      color: #888;
      cursor: pointer;
      font-size: 1rem;
      padding: 0;
      transition: color 0.2s;
    }

    .toggle-pass:hover { color: #D4A017; }

    .error {
      background: #3d1515;
      color: #ff6b6b;
      border-radius: 8px;
      padding: 0.65rem 1rem;
      font-size: 0.85rem;
      margin-bottom: 1rem;
      text-align: left;
    }

    .btn-primary {
      width: 100%;
      background-color: #D4A017;
      color: #1a1a1a;
      border: none;
      border-radius: 8px;
      padding: 0.85rem;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: background-color 0.2s;
    }

    .btn-primary:hover { background-color: #e6b020; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">🔒</div>
    <h1>Crear nueva contraseña</h1>
    <p class="subtitulo">Ingresa tu nueva contraseña para actualizar tu cuenta</p>

    <% if (error) { %>
      <div class="error">⚠️ <%= error %></div>
    <% } %>

    <form action="/password/nueva-password" method="POST">
      <div class="campo">
        <label for="nueva_password">Nueva contraseña</label>
        <div class="input-wrap">
          <span>🔒</span>
          <input type="password" id="nueva_password" name="nueva_password" placeholder="Mínimo 6 caracteres" required />
          <button type="button" class="toggle-pass" onclick="togglePass('nueva_password', this)">👁️</button>
        </div>
      </div>

      <div class="campo">
        <label for="confirmar_password">Confirmar contraseña</label>
        <div class="input-wrap">
          <span>🔒</span>
          <input type="password" id="confirmar_password" name="confirmar_password" placeholder="Repite la contraseña" required />
          <button type="button" class="toggle-pass" onclick="togglePass('confirmar_password', this)">👁️</button>
        </div>
      </div>

      <button type="submit" class="btn-primary">Actualizar contraseña</button>
    </form>
  </div>

  <script>
    function togglePass(id, btn) {
      const input = document.getElementById(id);
      if (input.type === 'password') {
        input.type = 'text';
        btn.textContent = '🙈';
      } else {
        input.type = 'password';
        btn.textContent = '👁️';
      }
    }
  </script>
</body>
</html>
