<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verificación – Fumi Dorado</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background-color: #1a1a1a;
      color: #ffffff;
      font-family: 'Segoe UI', sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .card {
      background-color: #242424;
      border-radius: 16px;
      padding: 2.5rem 2rem;
      width: 100%;
      max-width: 480px;
      text-align: center;
    }

    .logo {
      background-color: #D4A017;
      width: 70px;
      height: 70px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.5rem;
      font-size: 2rem;
    }

    h1 { font-size: 1.6rem; font-weight: 700; margin-bottom: 0.75rem; }

    .subtitulo { color: #aaaaaa; font-size: 0.95rem; margin-bottom: 0.5rem; }

    .telefono-mask {
      color: #D4A017;
      font-weight: 600;
      font-size: 1rem;
      margin-bottom: 1.75rem;
    }

    .codigo-label {
      font-size: 0.9rem;
      font-weight: 500;
      margin-bottom: 0.75rem;
    }

    .codigo-inputs {
      display: flex;
      justify-content: center;
      gap: 0.6rem;
      margin-bottom: 1.5rem;
    }

    .codigo-inputs input {
      width: 52px;
      height: 60px;
      background-color: #333;
      border: 1.5px solid #444;
      border-radius: 8px;
      color: #fff;
      font-size: 1.4rem;
      font-weight: 700;
      text-align: center;
      outline: none;
      transition: border-color 0.2s;
    }

    .codigo-inputs input:focus { border-color: #D4A017; }

    .error {
      background: #3d1515;
      color: #ff6b6b;
      border-radius: 8px;
      padding: 0.65rem 1rem;
      font-size: 0.85rem;
      margin-bottom: 1rem;
    }

    .btn-primary {
      width: 100%;
      background-color: #D4A017;
      color: #1a1a1a;
      border: none;
      border-radius: 8px;
      padding: 0.85rem;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: background-color 0.2s;
      margin-bottom: 1.25rem;
    }

    .btn-primary:hover { background-color: #e6b020; }

    .reenviar { font-size: 0.9rem; color: #aaa; }

    .reenviar button {
      background: none;
      border: none;
      color: #D4A017;
      cursor: pointer;
      font-size: 0.9rem;
      font-weight: 500;
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">🛡️</div>
    <h1>Verificación</h1>
    <p class="subtitulo">Ingresa el código enviado a tu celular</p>
    <p class="telefono-mask"><%= telefono %></p>

    <% if (error) { %>
      <div class="error">⚠️ <%= error %></div>
    <% } %>

    <form action="/password/verificar" method="POST">
      <p class="codigo-label">Código de verificación</p>
      <div class="codigo-inputs">
        <input type="text" name="d1" maxlength="1" inputmode="numeric" autofocus />
        <input type="text" name="d2" maxlength="1" inputmode="numeric" />
        <input type="text" name="d3" maxlength="1" inputmode="numeric" />
        <input type="text" name="d4" maxlength="1" inputmode="numeric" />
        <input type="text" name="d5" maxlength="1" inputmode="numeric" />
        <input type="text" name="d6" maxlength="1" inputmode="numeric" />
      </div>

      <button type="submit" class="btn-primary">Verificar código</button>
    </form>

    <div class="reenviar">
      ¿No recibiste el código?
      <form action="/password/recuperar" method="POST" style="display:inline">
        <input type="hidden" name="telefono" value="<%= telefono.replace('+57 ', '').replace(/\*/g, '') %>" />
        <button type="submit">Reenviar código</button>
      </form>
    </div>
  </div>

  <script>
    // Auto-avance entre los 6 campos del código
    const inputs = document.querySelectorAll('.codigo-inputs input');
    inputs.forEach((input, i) => {
      input.addEventListener('input', () => {
        if (input.value.length === 1 && i < inputs.length - 1) {
          inputs[i + 1].focus();
        }
      });
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Backspace' && input.value === '' && i > 0) {
          inputs[i - 1].focus();
        }
      });
    });
  </script>
</body>
</html>
