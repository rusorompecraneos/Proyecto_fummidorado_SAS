<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Recuperar Contraseña – Fumi Dorado</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background-color: #1a1a1a;
      color: #ffffff;
      font-family: 'Segoe UI', sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .card {
      background-color: #242424;
      border-radius: 16px;
      padding: 2.5rem 2rem;
      width: 100%;
      max-width: 480px;
      text-align: center;
    }

    .logo {
      background-color: #D4A017;
      color: #1a1a1a;
      font-weight: 700;
      font-size: 1.4rem;
      width: 64px;
      height: 64px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.5rem;
    }

    h1 { font-size: 1.6rem; font-weight: 700; margin-bottom: 0.75rem; }

    .subtitulo {
      color: #aaaaaa;
      font-size: 0.95rem;
      margin-bottom: 2rem;
      line-height: 1.5;
    }

    .campo { text-align: left; margin-bottom: 1.25rem; }

    .campo label {
      display: block;
      font-size: 0.9rem;
      font-weight: 500;
      margin-bottom: 0.4rem;
    }

    .input-wrap {
      display: flex;
      align-items: center;
      background-color: #333;
      border: 1.5px solid #444;
      border-radius: 8px;
      padding: 0 0.85rem;
      transition: border-color 0.2s;
    }

    .input-wrap:focus-within { border-color: #D4A017; }

    .input-wrap span { color: #888; font-size: 1.1rem; margin-right: 0.5rem; }

    .input-wrap input {
      background: transparent;
      border: none;
      outline: none;
      color: #fff;
      font-size: 0.95rem;
      padding: 0.75rem 0;
      width: 100%;
    }

    .error {
      background: #3d1515;
      color: #ff6b6b;
      border-radius: 8px;
      padding: 0.65rem 1rem;
      font-size: 0.85rem;
      margin-bottom: 1rem;
      text-align: left;
    }

    .btn-primary {
      width: 100%;
      background-color: #D4A017;
      color: #1a1a1a;
      border: none;
      border-radius: 8px;
      padding: 0.85rem;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: background-color 0.2s;
      margin-bottom: 1.25rem;
    }

    .btn-primary:hover { background-color: #e6b020; }

    .link-volver {
      color: #aaaaaa;
      text-decoration: none;
      font-size: 0.9rem;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      transition: color 0.2s;
    }

    .link-volver:hover { color: #D4A017; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">FD</div>
    <h1>Recuperar Contraseña</h1>
    <p class="subtitulo">Ingresa tu número de teléfono para recibir un código de verificación</p>

    <% if (error) { %>
      <div class="error">⚠️ <%= error %></div>
    <% } %>

    <form action="/password/recuperar" method="POST">
      <div class="campo">
        <label for="telefono">Número de teléfono</label>
        <div class="input-wrap">
          <span>📞</span>
          <input
            type="tel"
            id="telefono"
            name="telefono"
            placeholder="Ej: 3001234567"
            required
          />
        </div>
      </div>

      <button type="submit" class="btn-primary">Enviar código</button>
    </form>

    <a href="/auth/login" class="link-volver">← Volver al login</a>
  </div>
</body>
</html>