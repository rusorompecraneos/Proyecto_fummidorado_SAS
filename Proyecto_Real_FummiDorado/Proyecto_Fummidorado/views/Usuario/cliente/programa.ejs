<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Programa – Fumi Dorado</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <div style="min-height:100vh; background:var(--color-bg); padding: var(--space-8);">
    <div style="max-width: 1100px; margin: 0 auto; display:flex; flex-direction:column; gap: var(--space-8);">

      <!-- HEADER -->
      <div style="padding-bottom: var(--space-5); border-bottom: 2px solid var(--color-gold);">
        <a href="javascript:history.back()" class="page-header__back" style="margin-bottom: var(--space-3); display:inline-flex;">
          <span style="font-size:1.3rem; margin-right:var(--space-2);">←</span> Volver
        </a>
        <h1 class="page-header__title">Programa</h1>
        <p class="page-header__subtitle">Gestión de documentos y procedimientos</p>
      </div>

      <!-- GRID DE SECCIONES -->
      <div class="grid grid-3">

        <div class="card card--module">
          <div class="card__title">Competencia Personal</div>
          <div class="card__subtitle">Documentos sobre competencias y cualificaciones del personal</div>
          <div class="card__icon">📄</div>
        </div>

        <div class="card card--module">
          <div class="card__title">Conceptos Sanitarios</div>
          <div class="card__subtitle">Información sobre normativas y conceptos sanitarios aplicables</div>
          <div class="card__icon">📄</div>
        </div>

        <div class="card card--module">
          <div class="card__title">Cronograma</div>
          <div class="card__subtitle">Cronograma de servicios y actividades programadas</div>
          <div class="card__icon">📄</div>
        </div>

        <div class="card card--module">
          <div class="card__title">Disposición de Residuos</div>
          <div class="card__subtitle">Protocolos y procedimientos para manejo de residuos</div>
          <div class="card__icon">📄</div>
        </div>

        <div class="card card--module">
          <div class="card__title">Documentos SG-SST</div>
          <div class="card__subtitle">Sistema de Gestión de Seguridad y Salud en el Trabajo</div>
          <div class="card__icon">📄</div>
        </div>

        <div class="card card--module">
          <div class="card__title">Matriz de Rotación</div>
          <div class="card__subtitle">Planificación de rotación de productos y técnicas</div>
          <div class="card__icon">📄</div>
        </div>

      </div>
    </div>
  </div>
</body>
</html>